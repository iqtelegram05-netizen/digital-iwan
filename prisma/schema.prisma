generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  role      String   @default("user") // "user", "supervisor", "owner"
  isBlocked Boolean  @default(false)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription & Usage
  messagesUsed     Int      @default(0)
  bonusMessages    Int      @default(0)
  subscriptionExpiry DateTime?
  lastMessageResetDate DateTime? // 24h daily reset timer
  adsWatchedToday  Int      @default(0)
  adsWatchedTotal  Int      @default(0)
  lastAdDate       DateTime?

  chatSessions ChatSession[]
  quizResults  QuizResult[]
  profiles     UserProfile[]
  loginLogs    LoginLog[]
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  email     String
  action    String   @default("login") // "login" or "logout"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String?
  title     String?
  mode      String   @default("chat") // "chat", "debate", "teacher"
  scholar   String?
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user", "assistant", "system"
  content   String
  sources   String?  // JSON array of RAG sources
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String?
  category  String   // "عقائد", "منطق", "علم", "نحو", "فقه"
  score     Int
  total     Int      @default(100)
  answers   String   // JSON array of question/answer pairs
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String
  bio       String?
  interests String?  // JSON array
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model OwnerSettings {
  id        String   @id @default(cuid())
  ragLinks  String?  // JSON array of knowledge base URLs
  apiKeys   String?  // JSON array of {key, status, name, createdAt}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ad {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String?  // URL of ad banner image
  linkUrl     String?  // URL to redirect on click
  htmlCode    String?  // Custom HTML embed code (for AdSense etc)
  isActive    Boolean  @default(true)
  priority    Int      @default(0) // higher = shown first
  impressions Int     @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Prayer {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  category    String   @default("دعاء") // "دعاء" or "زيارة" or "خطب"
  text        String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Persistent Response Cache - same question = 1 AI call, saves tokens massively
model ResponseCache {
  id        String   @id @default(cuid())
  questionHash String  // hash of normalized question + mode + scholar
  mode      String   // "chat", "debate", "teacher", "research"
  scholar   String?  // optional scholar name
  question  String   // original question (for reference)
  answer    String   // AI response
  hitCount  Int      @default(0) // how many times served from cache
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionHash])
  @@index([mode])
}

model ApiProvider {
  id        String   @id @default(cuid())
  name      String   @unique // "gemini", "groq", "deepseek", "openai", etc
  label     String   // "Google Gemini", "Groq", etc
  baseUrl   String?  // custom base URL for the provider
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keys ApiKey[]
}

model ApiKey {
  id              String   @id @default(cuid())
  providerId      String
  encryptedKey    String   // AES encrypted API key
  keyFingerprint  String?  // first 8 chars for identification
  label           String?  // optional friendly label
  status          String   @default("active") // "active", "standby", "exhausted", "cooldown"
  tokensUsed      Int      @default(0)
  tokensLimit     Int?     // daily limit (optional)
  requestCount    Int      @default(0)
  lastUsedAt      DateTime?
  lastErrorAt     DateTime?
  lastError       String?  // last error message
  cooldownUntil   DateTime? // when key can be re-activated
  priority        Int      @default(0) // higher = used first
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provider ApiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}
